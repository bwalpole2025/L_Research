# ─────────────────────────────────────────────────────────────────────────────
# LaTeX Studio — PRODUCTION env for a single Linux host fronted by Cloudflare Tunnel.
#
#   cp .env.production.example .env.production    # then fill in every blank
#   cp .env.production .env                       # (so the bare `docker compose` command works)
#   docker compose --env-file .env.production \
#     -f docker-compose.yml -f docker-compose.prod.yml up -d --build
#
# .env.production is GITIGNORED — it holds real secrets; never commit it.
# Every var WITHOUT a default is REQUIRED: `up` fails fast if it is unset, and the
# api ALSO re-checks secret strength at boot. Full walk-through:
# docs/deploy-single-host.md.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ingress: Cloudflare Tunnel (the ONLY way in; no open host ports) ──────────
# Cloudflare Zero Trust → Networks → Tunnels → Create a tunnel → copy its token.
# Then add a Public Hostname for your domain pointing at the service http://web:3000.
CLOUDFLARE_TUNNEL_TOKEN=

# The public HTTPS URL you browse to (your tunnel's hostname). Used for pinned
# CORS and OAuth redirect URIs. No trailing slash.
PUBLIC_URL=https://latex.example.com

# ── API auth — a STRONG bearer is mandatory (the api refuses to boot without it) ─
# This is the SERVICE token the web app injects server-side; the browser never
# sees it. Generate with:  openssl rand -base64 32
API_BEARER_TOKEN=

# ── Multi-user auth (HOSTED tier) — Better Auth session/cookie signing secret ──
# The hosted tier runs with accounts (DEPLOY_PROFILE=production → AUTH_REQUIRED):
# every request needs a logged-in user. Generate with:  openssl rand -base64 32
BETTER_AUTH_SECRET=

# ── Credential vault + document-content encryption master key ─────────────────
# No OS keychain exists inside a container, so this env key is REQUIRED. It
# encrypts the credential vault AND document content at rest (per-project keys).
# KEEP IT SAFE AND BACKED UP — losing it makes encrypted content unrecoverable.
# Generate with:  openssl rand -base64 32
CONNECTORS_MASTER_KEY=

# ── Database secret ───────────────────────────────────────────────────────────
# openssl rand -base64 24   (avoid '@', ':' and '/' — they break the DATABASE_URL)
POSTGRES_PASSWORD=

# ── Host paths / ids ──────────────────────────────────────────────────────────
# Host directory backing the compile workspace (sources, build output, literature
# PDFs). A real path on the host disk — bind-mounted into api/texlive; pyrun uses
# it as the `docker run -v` source. Backed up nightly by scripts/backup.sh.
COMPILE_WORKSPACE=/srv/latex-studio/workspace

# The host's docker group id, so the NON-ROOT api can use the docker socket to
# drive texlive/pyrun:  getent group docker | cut -d: -f3
DOCKER_GID=999

# ── Resource caps (host protection; sensible defaults) ────────────────────────
TEXLIVE_CPUS=2
TEXLIVE_MEM=2g

# ── Untrusted-code isolation (gVisor + execution quotas; see docs/isolation.md) ─
# gVisor (runsc) wraps the texlive + pyrun sandboxes in a user-space kernel.
# REQUIRES gVisor installed on the host (docs/isolation.md → install). Opt out on
# a host without it: TEXLIVE_RUNTIME=runc and PYRUN_RUNTIME= (empty).
TEXLIVE_RUNTIME=runsc
PYRUN_RUNTIME=runsc
# Admission gate shared by compile + Python "Run" (server-side path).
EXEC_MAX_CONCURRENT=4        # total concurrent sandbox jobs across all users
EXEC_PER_USER_CONCURRENT=2   # max concurrent per user (one user can't starve the pool)
EXEC_PER_USER_DAILY_RUNS=500 # per-user/day server-side RUN quota (anti-miner; compiles uncapped)

# ── Backups (scripts/backup.sh) ───────────────────────────────────────────────
# Second on-host location to mirror nightly backups to (an attached disk is best).
BACKUP_MIRROR=/srv/latex-studio/backups-mirror
BACKUP_KEEP_DAYS=14

# ── Model / AI (optional) ─────────────────────────────────────────────────────
# NO ANTHROPIC_API_KEY — the boot guard rejects it under agent-sdk (ADR-004). AI
# features need the `claude login` subscription credential, which lives on a host
# keychain, not in this container — see docs/deploy-single-host.md → "AI".
MODEL=claude-sonnet-4-6
