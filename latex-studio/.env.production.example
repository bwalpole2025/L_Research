# ─────────────────────────────────────────────────────────────────────────────
# LaTeX Studio — PRODUCTION (private, self-hosted) environment.
#
#   cp .env.production.example .env.production   # then fill in the blanks
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# .env.production is GITIGNORED — it holds real secrets. Never commit it.
# Every var below without a default is REQUIRED; `up` fails fast if it is unset.
# Full walk-through: docs/self-hosting.md.
# ─────────────────────────────────────────────────────────────────────────────

# ── Tunnel / front door (Section 1) ──────────────────────────────────────────
# The PRIVATE interface Caddy binds to. This is your Tailscale (100.x.y.z) or
# WireGuard (10.x.y.z) address on THIS host — NEVER 0.0.0.0 / a public IP.
#   Tailscale:  tailscale ip -4
TUNNEL_BIND_ADDR=100.x.y.z
# The hostname you browse to over the tunnel (used for TLS + pinned CORS).
#   Tailscale MagicDNS:  <host>.<tailnet>.ts.net
TUNNEL_HOSTNAME=latex.your-tailnet.ts.net
# Published port on the tunnel interface (https). Default 8443.
TUNNEL_PORT=8443

# ── API auth — STRONG bearer is mandatory off-loopback (Section 2) ────────────
# The api refuses to boot bound off-loopback without this. Generate with:
#   openssl rand -hex 32
API_BEARER_TOKEN=

# ── Database secret (Section 4) ──────────────────────────────────────────────
POSTGRES_USER=latex
# openssl rand -hex 24
POSTGRES_PASSWORD=
POSTGRES_DB=latex_studio

# ── Credential vault master key (no OS keychain inside a container) ──────────
# openssl rand -hex 32
CONNECTORS_MASTER_KEY=

# ── Host docker group id, so the non-root api can use the docker socket ──────
#   getent group docker | cut -d: -f3
DOCKER_GID=999

# ── Persistence (Section 5) — host dir backing the compile workspace ─────────
# A real path on the host's disk. Bind-mounted into api/texlive; pyrun uses it as
# the `docker run -v` source. Back it up nightly (scripts/backup.sh).
COMPILE_WORKSPACE_HOST=/srv/latex-studio/workspace

# ── Model / AI ───────────────────────────────────────────────────────────────
# NO ANTHROPIC_API_KEY (the boot guard rejects it under agent-sdk, ADR-004).
# NOTE: AI features need the `claude login` subscription credential, which lives
# on a host keychain — see docs/self-hosting.md → "AI in the container".
MODEL=claude-sonnet-4-6

# ── Resource caps (host protection; defaults are sensible) ───────────────────
TEXLIVE_CPUS=2
TEXLIVE_MEM=2g
COMPILE_MAX_CONCURRENT=2
RATE_LIMIT_COMPILE_MAX=30
RATE_LIMIT_RUN_MAX=20
RATE_LIMIT_AI_MAX=120

# ── Optional: local LanguageTool (prose grammar) ─────────────────────────────
# LANGUAGETOOL_URL=http://languagetool:8010
