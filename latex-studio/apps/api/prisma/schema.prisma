// LaTeX Studio — Prisma schema.
// Single-user app: no auth tables. Access is gated by a bearer token at the
// API layer and a localhost-only bind (see README).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// App-level folder hierarchy that ORGANISES projects on Home (like documents on a
// computer). It groups projects only — it has no projectId and never touches a
// project's internal files/paths. A project lives in exactly one folder, or at the
// root (folderId null = "Unfiled"). Subtree deletes go to TrashEntry (kind
// 'project-folder', projectId null) and restore rebuilds the structure.
model ProjectFolder {
  id        String   @id @default(cuid())
  parentId  String?
  name      String
  createdAt DateTime @default(now())

  parent   ProjectFolder?  @relation("ProjectFolderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children ProjectFolder[] @relation("ProjectFolderChildren")
  projects Project[]

  // Prevent sibling name collisions (NULL parent collisions are also checked in the route).
  @@unique([parentId, name])
}

model Project {
  id        String   @id @default(cuid())
  name      String
  rootFile  String   @default("main.tex")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Which Home folder organises this project; null = root ("Unfiled"). Purely
  // organisational — moving a project changes only this column, never its files.
  folderId String?

  // Mathcheck settings (Project settings page).
  macros      Json?
  assumptions String @default("")

  // AI settings (Project settings page).
  model          String @default("claude-sonnet-4-6")
  aiInstructions String @default("")
  // Which MODEL CONNECTOR powers this project's AI: "anthropic" | "chatgpt" | "gemini".
  // Auth is owned by the vendor CLI (no API key); see the Connectors framework.
  aiProvider     String @default("anthropic")

  // Prose-check per-project custom dictionary (domain terms, names).
  customWords String[] @default([])

  // Python "Run" settings. pythonRunTarget is the default entry .py to run
  // (empty ⇒ run the active file). networkEnabled opts this project's sandbox
  // into network access (off by default; see ADR-013).
  pythonRunTarget String  @default("")
  networkEnabled  Boolean @default(false)

  // Compile settings. texEngine selects the latexmk engine flag
  // (pdflatex → -pdf, xelatex → -pdfxe, lualatex → -pdflua). haltOnError stops
  // at the first error (latexmk -halt-on-error); draftMode skips image
  // rendering for a faster preview (graphicx draft via latexmk -usepretex).
  texEngine   String  @default("pdflatex")
  haltOnError Boolean @default(false)
  draftMode   Boolean @default(false)

  // Lifecycle. A project is ACTIVE when both are null. `archivedAt` set ⇒ set
  // aside (hidden from the main list + editor, fully restorable). `deletedAt`
  // set ⇒ in the Trash (soft-deleted; restorable until purged). The default
  // project list and the editor only ever see active projects.
  archivedAt DateTime?
  deletedAt  DateTime?

  files       TexFile[]
  compileLogs CompileLog[]
  snapshots   Snapshot[]
  chatThreads ChatThread[]
  folders     Folder[]
  literature  LiteratureItem[]
  trash       TrashEntry[]

  folder ProjectFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([folderId])
  @@index([archivedAt])
  @@index([deletedAt])
}

// Hierarchical folders for BOTH trees (one mechanism). `tree` distinguishes the
// source file tree from the literature library tree.
enum FolderTree {
  source
  literature
}

model Folder {
  id        String     @id @default(cuid())
  projectId String
  parentId  String?
  name      String
  tree      FolderTree
  createdAt DateTime   @default(now())

  project  Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   Folder?          @relation("FolderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[]         @relation("FolderChildren")
  items    LiteratureItem[]

  // Prevent sibling name collisions (NULL parent collisions are also checked in the route).
  @@unique([projectId, tree, parentId, name])
  @@index([projectId, tree])
}

// A library article: metadata + a pointer to the PDF on the compile-workspace
// volume. PDF bytes are NEVER stored in Postgres.
model LiteratureItem {
  id            String    @id @default(cuid())
  projectId     String
  folderId      String?
  title         String    @default("")
  authors       String    @default("")
  year          String    @default("")
  citeKey       String?
  fileName      String    @default("")
  storagePath   String    @default("")
  fileSizeBytes Int       @default(0)
  doi           String?
  abstract      String?
  extractedText String?
  extractedAt   DateTime?
  // Provenance: which connector/source this item came from ("upload", "arxiv",
  // "crossref", "zotero", "semantic-scholar", "google-drive", …).
  source        String    @default("upload")
  addedAt       DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder  Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  chunks  LibraryChunk[]

  @@index([projectId])
  @@index([projectId, citeKey])
}

// A retrievable ~400–500-token passage of a LiteratureItem's extracted text, with
// its LOCAL embedding (pgvector). Powers the RAG-grounded document check: a
// physics/citation discrepancy may only be asserted when backed by a chunk
// retrieved from here. The embedding column is queried via raw SQL (Prisma can't
// type pgvector's `<=>` operator / op-class index). PDF bytes never live in PG —
// only this extracted text does.
model LibraryChunk {
  id               String                     @id @default(cuid())
  literatureItemId String
  projectId        String
  page             Int                        @default(0)
  charStart        Int                        @default(0)
  charEnd          Int                        @default(0)
  text             String
  embedding        Unsupported("vector(384)")
  model            String                     @default("")
  createdAt        DateTime                   @default(now())

  item LiteratureItem @relation(fields: [literatureItemId], references: [id], onDelete: Cascade)

  @@index([literatureItemId])
  @@index([projectId])
}

// Soft-delete: deletes go here, not oblivion. payload holds enough to restore.
// projectId is null for APP-LEVEL entries (kind 'project-folder'), which organise
// projects on Home and aren't owned by any single project.
model TrashEntry {
  id        String   @id @default(cuid())
  projectId String?
  kind      String // 'file' | 'folder' | 'literature' | 'project-folder'
  payload   Json
  deletedAt DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// Chat transcript — WE own it (source of truth), replayed to the provider per
// query rather than relying on the SDK's session/resume (see ADR-005).
model ChatThread {
  id        String   @id @default(cuid())
  projectId String
  title     String   @default("Chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([projectId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  role      String // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

// Per-call AI latency/outcome — visibility into Agent SDK overhead per surface.
model AiCallLog {
  id        String   @id @default(cuid())
  projectId String?
  route     String // "chat" | "edit" | "fix" | "health" | "complete"
  provider  String? // "agent-sdk" | "api"
  model     String
  variant   String? // completions: "warm" | "cold" | "baseline"
  latencyMs Int
  ok        Boolean
  errorKind String? // AiErrorKind, when ok = false
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
  @@index([route])
}

model TexFile {
  id        String   @id @default(cuid())
  projectId String
  path      String
  // Nullable → root of the source tree. Prep for the source-tree folderId
  // migration; the path column remains the source of truth for compile/SyncTeX.
  folderId  String?
  content   String   @default("")
  // "utf8" for text, "base64" for uploaded binary files (figures, fonts, PDFs).
  encoding  String   @default("utf8")
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, path])
  @@index([projectId])
}

model CompileLog {
  id         String   @id @default(cuid())
  projectId  String
  status     String // "success" | "error"
  log        String
  durationMs Int      @default(0)
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// Lightweight versioning: a labelled, point-in-time copy of a project's files
// stored as JSONB so a snapshot is independent of later edits.
model Snapshot {
  id        String   @id @default(cuid())
  projectId String
  label     String
  files     Json
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// Adaptive autocomplete usage. `scope` is "app" for cross-project typing habits
// (commands, environments, snippets, packages) or a project id for document-
// specific keys (cite keys, labels, file paths). `score` is the decayed
// frequency+recency sum at `lastUsedAt` (see @latex-studio/shared usage scoring).
// Local usage data only — never sent anywhere external.
model UsageStat {
  id          String   @id @default(cuid())
  scope       String // "app" | <projectId>
  key         String // "cmd:frac", "env:align", "snippet:figure", "cite:basset1888", …
  count       Int      @default(0)
  score       Float    @default(0)
  firstUsedAt DateTime @default(now())
  lastUsedAt  DateTime @default(now())

  @@unique([scope, key])
  @@index([scope])
}

// Encrypted credential vault for connectors (single row per connector). The
// secret (OAuth token JSON, or an API key) is stored ONLY as AES-256-GCM
// ciphertext — never plaintext, never sent to the browser. Model connectors do
// NOT appear here: their auth is owned by the vendor CLI. See vault/ + oauth/.
model Credential {
  id           String    @id @default(cuid())
  connectorId  String    @unique
  authType     String // "oauth2" | "apiKey"
  accountLabel String? // e.g. the connected account email (display only)
  scopes       String[]  @default([])
  // AES-256-GCM parts (base64). `ciphertext` holds the encrypted secret JSON.
  ciphertext   String
  iv           String
  tag          String
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
