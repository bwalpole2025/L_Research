{
  "name": "@latex-studio/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fastify API: projects, compilation, AI proxy, mathcheck proxy.",
  "main": "src/server.ts",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"prisma/**/*.ts\" \"test/**/*.ts\"",
    "test": "dotenv -e ../../.env -- vitest run",
    "test:watch": "dotenv -e ../../.env -- vitest",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.173",
    "@fastify/cors": "^9.0.1",
    "@fastify/sensible": "^5.6.0",
    "@latex-studio/shared": "workspace:*",
    "@prisma/client": "^5.17.0",
    "dictionary-en-gb": "^3.0.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "nspell": "^2.1.5",
    "pdfjs-dist": "^4.6.82",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "dotenv-cli": "^7.4.2",
    "eslint": "^8.57.0",
    "prisma": "^5.17.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.4"
  }
}
