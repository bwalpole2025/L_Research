# ─────────────────────────────────────────────────────────────────────────────
# LaTeX Studio — LOCAL (private, VPN-only) tier. Single-user, NO accounts, NO
# public ingress: "your data never leaves your machine". See docs/deployment-tiers.md
# and docs/self-hosting.md.
#
#   cp .env.local.example .env.local             # then fill in every blank
#   cp .env.local .env                           # (so the bare `docker compose` command works)
#   docker compose --env-file .env.local \
#     -f docker-compose.yml -f docker-compose.local.yml up -d --build
#
# .env.local is GITIGNORED — it holds real secrets; never commit it.
# Every var WITHOUT a default is REQUIRED: `up` fails fast if it is unset, and the
# api also re-checks secret strength at boot.
# ─────────────────────────────────────────────────────────────────────────────

# ── Front door: Caddy on your VPN interface (the only published port) ─────────
# The PRIVATE interface Caddy binds to — your Tailscale (100.x.y.z) or WireGuard
# (10.x.y.z) address on THIS host. NEVER 0.0.0.0 / a public IP.
#   Tailscale:  tailscale ip -4
TUNNEL_BIND_ADDR=100.x.y.z
# The hostname you browse to over the VPN (used for TLS + pinned CORS).
#   Tailscale MagicDNS:  <host>.<tailnet>.ts.net
TUNNEL_HOSTNAME=latex.your-tailnet.ts.net
# Published port on the VPN interface (https). Default 8443.
TUNNEL_PORT=8443

# ── API auth — a STRONG bearer is mandatory (the api refuses to boot without it) ─
# Single-user tier: there are no logins; the bearer + the VPN are the access
# control. Generate with:  openssl rand -base64 32
API_BEARER_TOKEN=

# ── Credential vault + document-content encryption master key ─────────────────
# No OS keychain inside a container, so this is REQUIRED. Encrypts the credential
# vault AND document content at rest. BACK IT UP — losing it loses encrypted data.
# Generate with:  openssl rand -base64 32
CONNECTORS_MASTER_KEY=

# ── Database secret ───────────────────────────────────────────────────────────
# openssl rand -base64 24   (avoid '@', ':' and '/' — they break the DATABASE_URL)
POSTGRES_PASSWORD=

# ── Host paths / ids ──────────────────────────────────────────────────────────
# Host directory backing the compile workspace (sources, build output, literature
# PDFs). Bind-mounted into api/texlive; pyrun uses it as the `docker run -v` source.
COMPILE_WORKSPACE=/srv/latex-studio/workspace
# Host docker group id, so the NON-ROOT api can use the docker socket:
#   getent group docker | cut -d: -f3
DOCKER_GID=999

# ── Resource caps + backups (sensible defaults) ───────────────────────────────
TEXLIVE_CPUS=2
TEXLIVE_MEM=2g
BACKUP_MIRROR=/srv/latex-studio/backups-mirror
BACKUP_KEEP_DAYS=14

# ── Model / AI (optional) ─────────────────────────────────────────────────────
# NO ANTHROPIC_API_KEY (the boot guard rejects it under agent-sdk, ADR-004). AI
# needs the `claude login` subscription credential on a host keychain — see the
# runbook. Core editing/compile/preview work without it.
MODEL=claude-sonnet-4-6
