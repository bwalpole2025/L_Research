# ─── Database ────────────────────────────────────────────────────────────────
# Used by HOST-side tooling: `prisma migrate`, `prisma seed`, and `pnpm dev`
# (which runs the api on your host). It points at the Postgres that
# docker-compose publishes on localhost.
#
# NOTE: the api *container* (docker compose --profile full) ignores this and uses
# an internal URL with host `postgres`, injected by docker-compose. You don't
# need to touch that.
DATABASE_URL="postgresql://latex:latex@localhost:5432/latex_studio?schema=public"

# ─── AI (Claude Agent SDK over your subscription) ────────────────────────────
# NO API KEY. AI features use the Claude Agent SDK billed to your Claude
# subscription via `claude login` (see README → AI features). The api REFUSES
# TO BOOT if ANTHROPIC_API_KEY or ANTHROPIC_AUTH_TOKEN is set under agent-sdk,
# because the SDK would silently use the key and bill the API (ADR-004).
#
# Provider: "agent-sdk" (default, subscription) or "api" (pay-as-you-go stub).
MODEL_PROVIDER="agent-sdk"
# Default chat/edit model (overridable per project in Settings).
MODEL="claude-sonnet-4-6"
# Inline completions (ghost text). Completions on agent-sdk exceed the 1.5s p95
# budget (SDK overhead, ADR-006); set COMPLETIONS_PROVIDER=api to route ONLY the
# /complete path to a metered key. Defaults below are optional.
# COMPLETIONS_PROVIDER="agent-sdk"
# COMPLETION_MODEL="claude-haiku-4-5"   # fastest (Haiku-class), independent of chat
# COMPLETIONS_WARM="true"               # keep a pre-warmed SDK pool per project
# COMPLETION_WARM_IDLE_MS="600000"      # idle-kill the warm pool after 10 min

# ─── Prose check (Phase 7) ───────────────────────────────────────────────────
# Optional LOCAL LanguageTool container for grammar/style (no text leaves the
# machine). Start it with `docker compose --profile prose up -d languagetool`,
# then set this. When unset, the prose check runs spelling (en-GB) + lints only.
# Host-run api: http://127.0.0.1:8010 ; api container: http://languagetool:8010
# LANGUAGETOOL_URL="http://127.0.0.1:8010"

# ─── API auth ────────────────────────────────────────────────────────────────
# Shared bearer token required on every non-health request to the api.
# Generate one with:  openssl rand -hex 32
# Required by `docker compose up` (compose fails fast if it is unset).
API_BEARER_TOKEN="replace-with-a-long-random-string"

# ─── MathCheck service ───────────────────────────────────────────────────────
# Where the api reaches the SymPy verification microservice. Inside docker the
# api container uses http://mathcheck:8000 automatically; this localhost value is
# for a host-run api (`pnpm dev`).
MATHCHECK_URL="http://127.0.0.1:8000"

# ─── LaTeX toolchain ─────────────────────────────────────────────────────────
# docker = compile by `docker exec`-ing latexmk in the texlive container.
# local  = spawn a latexmk installed on your host machine.
TEXLIVE_MODE="docker"

# Host directory holding per-project compile working dirs. Bind-mounted into the
# texlive container at /workspace (see docker-compose.yml), so the host-run api
# and texlive share files directly. Default: <repo>/.compile-workspace.
# COMPILE_WORKSPACE="/absolute/path/to/.compile-workspace"

# Name of the texlive container the api execs into (docker mode).
TEXLIVE_CONTAINER="latex-studio-texlive"

# Hard compile timeout (ms). The process group is killed on timeout.
COMPILE_TIMEOUT_MS="120000"

# ─── Python "Run" sandbox (pyrun) ────────────────────────────────────────────
# Executes a project's .py in a SANDBOX, separate from LaTeX compilation.
# docker = a fresh `docker run --rm` per execution from the pyrun image: non-root,
#          resource/time-limited, network OFF by default (per-project opt-in).
# local  = spawn host `python3` directly — DEV/TEST ONLY, NOT sandboxed (ADR-013).
PYRUN_MODE="docker"

# Image the sandbox runs (built by the `pyrun` compose service).
PYRUN_IMAGE="latex-studio-pyrun"

# HOST path of the compile workspace, used as the `docker run -v` mount source so
# the sandbox can read the project files. Defaults to COMPILE_WORKSPACE; override
# only if the api itself runs inside a container.
# PYRUN_WORKSPACE_HOST="/absolute/path/to/.compile-workspace"

# Hard wall-clock timeout for a run (ms). The container is SIGKILLed on expiry.
PYRUN_TIMEOUT_MS="60000"

# Sandbox resource caps and user (docker run --cpus/--memory/--pids-limit/--user).
PYRUN_CPUS="1"
PYRUN_MEMORY="512m"
PYRUN_PIDS_LIMIT="256"
PYRUN_USER="1000:1000"

# ─── Web → API ───────────────────────────────────────────────────────────────
# The Next.js server proxies browser calls under /api/* to the Fastify api and
# injects the bearer token server-side (see apps/web/app/api/[...path]/route.ts),
# so the token never reaches the browser. This is the api's URL as seen by the
# Next server.
API_INTERNAL_URL="http://127.0.0.1:4000"

# ─── Connectors framework ─────────────────────────────────────────────────────
# Credentials (OAuth tokens / API keys) are encrypted at rest. The MASTER KEY is
# taken from the OS keychain first (preferred); this env var is the fallback for
# Docker / headless / CI, where the keychain is unavailable. Generate one with:
#   openssl rand -base64 32
# Leave unset to rely solely on the keychain (host runs only). See docs/decisions.md.
# CONNECTORS_MASTER_KEY=""

# Public URL the api is reachable at, used to build OAuth redirect URIs
# (<base>/connectors/:id/callback). Defaults to the localhost bind.
# OAUTH_REDIRECT_BASE_URL="http://127.0.0.1:4000"
# Where the web app lives — the OAuth callback redirects back here after consent.
# WEB_BASE_URL="http://127.0.0.1:3000"

# OAuth client credentials for the storage/content connectors. Register an OAuth
# app with each provider (redirect URI: <OAUTH_REDIRECT_BASE_URL>/connectors/<id>/callback),
# then set its client id/secret here. NEVER committed; never sent to the browser.
#   Google Drive — https://console.cloud.google.com (OAuth consent + credentials)
# GOOGLE_OAUTH_CLIENT_ID=""
# GOOGLE_OAUTH_CLIENT_SECRET=""
#   Notion — https://www.notion.so/my-integrations (public OAuth integration)
# NOTION_OAUTH_CLIENT_ID=""
# NOTION_OAUTH_CLIENT_SECRET=""
#   Dropbox — https://www.dropbox.com/developers/apps (scoped app; redirect URI as above)
# DROPBOX_OAUTH_CLIENT_ID=""
# DROPBOX_OAUTH_CLIENT_SECRET=""
#   OneDrive — https://portal.azure.com (App registration; Microsoft Graph Files.ReadWrite)
# ONEDRIVE_OAUTH_CLIENT_ID=""
# ONEDRIVE_OAUTH_CLIENT_SECRET=""

# Literature sources. arXiv + CrossRef are open (no key). Zotero needs a key
# (https://www.zotero.org/settings/keys); Semantic Scholar works without a key
# but a key raises rate limits (https://www.semanticscholar.org/product/api).
# These may also be set per connector in the Plugins UI (stored encrypted).
# ZOTERO_API_KEY=""
# SEMANTIC_SCHOLAR_API_KEY=""

# Model connectors use NO API KEY: they run on your subscription via each
# vendor's official CLI. Install + sign in once, then pick the provider per
# project in Settings → AI:
#   Claude  — `npm i -g @anthropic-ai/claude-code` then `claude login`
#   ChatGPT — `npm i -g @openai/codex`            then run `codex` → Sign in with ChatGPT
#   Gemini  — `npm i -g @google/gemini-cli`       then run `gemini` → Login with Google
